<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|ico|css|js|woff2?|eot|ttf|otf)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=0, must-revalidate, public"
  </FilesMatch>
</IfModule>
<IfModule mod_authz_core.c>
  <FilesMatch "^(?:README\.md|\.htaccess|wp-config\.php(?:\..*)?)$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "^(?:README\.md|\.htaccess|wp-config\.php(?:\..*)?)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]
  RewriteRule (^|/)(?:README\.md|wp-config\.php(?:\..*)?)$ - [F,L,NC]
  RewriteRule \.(?:bak|old|orig|save|swp|swo|tmp|temp|dist|sql)(?:~)?$ - [F,L,NC]
</IfModule>
